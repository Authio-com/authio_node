{
  "name": "@useauthio/node",
  "version": "0.2.0",
  "description": "Authio server-side SDK for Node.js, Bun, Deno, and edge runtimes.",
  "author": "Authio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/authio-com/authio_node.git"
  },
  "homepage": "https://authio.com",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --out-dir dist",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --out-dir dist",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1"
    }
  }
}
